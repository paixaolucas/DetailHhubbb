{
  "name": "comunidade-hub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "start": "next dev -p 3000",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
