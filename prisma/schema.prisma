// =============================================================================
// REPORT / MODERATION
// =============================================================================

enum ReportTargetType {
  POST
  COMMENT
  USER
}

enum ReportStatus {
  PENDING
  RESOLVED
  IGNORED
}

model Report {
  id           String           @id @default(cuid())
  reportedById String
  targetType   ReportTargetType
  targetId     String
  reason       String
  status       ReportStatus     @default(PENDING)
  resolvedAt   DateTime?
  resolvedBy   String?
  createdAt    DateTime         @default(now())
  reportedBy   User             @relation("UserReports", fields: [reportedById], references: [id])

  @@index([status])
  @@index([targetType, targetId])
  @@index([reportedById])
  @@map("reports")
}

// =============================================================================
// PLATFORM SUBSCRIPTION (assinatura única da plataforma)
// =============================================================================

model PlatformPlan {
  id              String               @id @default(cuid())
  name            String
  description     String?
  price           Decimal
  currency        String               @default("brl")
  interval        String               @default("year")
  intervalCount   Int                  @default(1)
  trialDays       Int                  @default(0)
  features        Json                 @default("[]")
  isActive        Boolean              @default(true)
  stripePriceId   String?              @unique
  stripeProductId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  memberships     PlatformMembership[]

  @@map("platform_plans")
}

model PlatformMembership {
  id                     String                   @id @default(cuid())
  userId                 String                   @unique
  planId                 String
  status                 PlatformMembershipStatus @default(ACTIVE)
  stripeSubscriptionId   String?                  @unique
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  tier                   PlatformMembershipTier   @default(STANDARD)
  cancelAtPeriodEnd      Boolean                  @default(false)
  canceledAt             DateTime?
  joinedAt               DateTime                 @default(now())
  metadata               Json                     @default("{}")
  referredByInfluencerId String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  user                   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                   PlatformPlan             @relation(fields: [planId], references: [id])
  referredByInfluencer   Influencer?              @relation("InfluencerReferrals", fields: [referredByInfluencerId], references: [id])
  payments               Payment[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([referredByInfluencerId])
  @@map("platform_memberships")
}

// =============================================================================
// COMMUNITY OPT-IN
// Lightweight "I belong here" declaration within a platform subscription.
// Access (subscription) ≠ Belonging (opt-in).
// =============================================================================

model CommunityOptIn {
  id          String    @id @default(cuid())
  userId      String
  communityId String
  joinedAt    DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@index([communityId])
  @@index([userId])
  @@map("community_opt_ins")
}

enum PlatformMembershipStatus {
  ACTIVE
  CANCELED
  EXPIRED
  PAST_DUE
  TRIALING
}

enum PlatformMembershipTier {
  STANDARD
  PREMIUM
}

// =============================================================================
// PERFORMANCE SCORE
// Monthly PP (Pontuação de Performance) snapshot per influencer.
// Calculated and stored at the end of each month.
// =============================================================================

model InfluencerMonthlyScore {
  id                   String    @id @default(cuid())
  influencerId         String
  year                 Int
  month                Int       // 1–12
  // Raw component scores (0–100 each)
  scoreViews           Float     @default(0)
  scoreEngagement      Float     @default(0)
  scoreNewMembers      Float     @default(0)
  scoreRetention       Float     @default(0)
  scoreDeliveries      Float     @default(0)
  // Weighted total PP (0–100)
  totalPP              Float     @default(0)
  // Pool share this month (0–1)
  poolShare            Float     @default(0)
  // Source counts (for auditability)
  qualifiedViews       Int       @default(0)
  engagementActions    Int       @default(0)
  newActiveMembers     Int       @default(0)
  retentionRate        Float     @default(0)
  deliveriesCompleted  Int       @default(0)
  deliveriesRequired   Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  influencer           Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@unique([influencerId, year, month])
  @@index([influencerId])
  @@index([year, month])
  @@map("influencer_monthly_scores")
}

// =============================================================================
// INFLUENCER MILESTONES
// Records each milestone unlocked by an influencer (Bronze, Prata, Ouro, etc.)
// =============================================================================

model InfluencerMilestone {
  id           String        @id @default(cuid())
  influencerId String
  type         MilestoneType
  achievedAt   DateTime      @default(now())
  bonusAmount  Decimal       @default(0)
  bonusPaid    Boolean       @default(false)
  bonusPaidAt  DateTime?
  // Extra context: e.g. { month: "2025-01", membersCount: 55, rank: 1 }
  metadata     Json          @default("{}")
  createdAt    DateTime      @default(now())
  influencer   Influencer    @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@index([influencerId])
  @@index([type])
  @@index([bonusPaid])
  @@map("influencer_milestones")
}

enum MilestoneType {
  BRONZE                // first month ≥50 active referred members
  PRATA                 // 200 active referred members for 2 consecutive months
  OURO                  // 500 active referred members for 3 consecutive months
  TOP_CREATOR_MONTH     // rank #1 PP in a closed month
  CRESCIMENTO_ACELERADO // +100 new referred members in a single month
  EMBAIXADOR            // 12 consecutive months at 100% contract deliveries
}

// =============================================================================
// EVENTS & TICKETS
// Influencers can create events (online, in-person or hybrid) with paid or
// free ticket types. Members register and receive a confirmation.
// =============================================================================

enum EventType {
  ONLINE
  IN_PERSON
  HYBRID
}

enum EventStatus {
  DRAFT
  PUBLISHED
  SOLD_OUT
  CANCELED
  COMPLETED
}

enum EventRegistrationStatus {
  CONFIRMED
  PENDING_PAYMENT
  CANCELED
  ATTENDED
}

model Event {
  id            String        @id @default(cuid())
  hostId        String
  communityId   String?
  title         String
  slug          String        @unique
  description   String?
  coverImageUrl String?
  type          EventType     @default(ONLINE)
  status        EventStatus   @default(DRAFT)
  startAt       DateTime
  endAt         DateTime?
  timezone      String        @default("America/Sao_Paulo")
  location      String?       // address/venue for IN_PERSON/HYBRID
  onlineUrl     String?       // meeting link for ONLINE/HYBRID
  capacity      Int?          // null = unlimited
  isPublic      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  host          User          @relation("HostedEvents", fields: [hostId], references: [id])
  community     Community?    @relation(fields: [communityId], references: [id])
  ticketTypes   EventTicketType[]
  registrations EventRegistration[]

  @@index([hostId])
  @@index([communityId])
  @@index([status])
  @@index([startAt])
  @@map("events")
}

model EventTicketType {
  id            String              @id @default(cuid())
  eventId       String
  name          String
  description   String?
  price         Decimal             @default(0)
  currency      String              @default("brl")
  quantity      Int?                // null = unlimited
  sold          Int                 @default(0)
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  event         Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations EventRegistration[]

  @@index([eventId])
  @@map("event_ticket_types")
}

model EventRegistration {
  id           String                  @id @default(cuid())
  eventId      String
  userId       String
  ticketTypeId String
  status       EventRegistrationStatus @default(CONFIRMED)
  paymentId    String?
  amount       Decimal                 @default(0)
  checkedInAt  DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  event        Event                   @relation(fields: [eventId], references: [id])
  user         User                    @relation(fields: [userId], references: [id])
  ticketType   EventTicketType         @relation(fields: [ticketTypeId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("event_registrations")
}

// =============================================================================
// ADVERTISERS MODULE
// Companies (automotive aesthetics brands, suppliers, etc.) that pay to run
// ad campaigns targeting the platform's member base.
// =============================================================================

enum AdFormat {
  BANNER_FEED     // banner shown inline in the community feed
  SPONSORED_POST  // native-style sponsored post in the feed
  EMAIL_BLAST     // email sent to all active platform members
}

enum AdCampaignStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
}

model Advertiser {
  id          String       @id @default(cuid())
  userId      String       @unique
  companyName String
  website     String?
  logoUrl     String?
  bio         String?
  phone       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns   AdCampaign[]

  @@map("advertisers")
}

model AdCampaign {
  id              String           @id @default(cuid())
  advertiserId    String
  title           String
  description     String?
  format          AdFormat
  status          AdCampaignStatus @default(DRAFT)
  budget          Decimal          // total campaign budget in BRL
  spent           Decimal          @default(0)
  startDate       DateTime?
  endDate         DateTime?
  targetUrl       String?          // click destination
  creativeUrl     String?          // banner/image URL
  ctaText         String?          // call-to-action button text
  impressions     Int              @default(0)
  clicks          Int              @default(0)
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  advertiser      Advertiser       @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  @@index([advertiserId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("ad_campaigns")
}

// =============================================================================
// EXTERNAL MENTIONS
// Manually registered external mentions of the platform by influencers.
// (Instagram stories, YouTube end cards, WhatsApp convocations, etc.)
// Platform-tracked deliveries (videos, lives, forum) come from their own models.
// =============================================================================

model InfluencerExternalMention {
  id           String     @id @default(cuid())
  influencerId String
  year         Int
  month        Int        // 1–12
  platform     String     // "instagram" | "youtube" | "whatsapp" | "tiktok" | "other"
  url          String?    // proof link when available
  description  String     // brief description of the mention
  createdAt    DateTime   @default(now())
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@index([influencerId, year, month])
  @@map("influencer_external_mentions")
}

// ─── STUDY GROUPS ─────────────────────────────────────────────────────────────

model StudyGroup {
  id          String             @id @default(cuid())
  communityId String
  creatorId   String
  name        String
  description String?
  maxMembers  Int                @default(10)
  isOpen      Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  community   Community          @relation(fields: [communityId], references: [id], onDelete: Cascade)
  creator     User               @relation("StudyGroupCreator", fields: [creatorId], references: [id])
  members     StudyGroupMember[]

  @@index([communityId])
  @@map("study_groups")
}

model StudyGroupMember {
  id           String     @id @default(cuid())
  studyGroupId String
  userId       String
  joinedAt     DateTime   @default(now())
  studyGroup   StudyGroup @relation(fields: [studyGroupId], references: [id], onDelete: Cascade)
  user         User       @relation("StudyGroupMembership", fields: [userId], references: [id])

  @@unique([studyGroupId, userId])
  @@map("study_group_members")
}
